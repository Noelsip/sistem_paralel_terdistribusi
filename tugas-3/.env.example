# ===== Node Identity =====
NODE_ID=node-1
NODE_HOST=0.0.0.0
NODE_PORT=8001
# Comma-separated peer node IDs (must match other nodes' NODE_ID values)
PEERS=node-2,node-3

# ===== Raft Consensus =====
# Election timeout window (seconds). Randomised per node to avoid split votes.
ELECTION_TIMEOUT_MIN=0.15
ELECTION_TIMEOUT_MAX=0.30
HEARTBEAT_INTERVAL=0.05
RPC_TIMEOUT=0.1

# ===== Distributed Queue =====
VIRTUAL_NODES=150
PERSISTENCE_PATH=/var/lib/distsync
MAX_QUEUE_SIZE=10000
REPLICATION_FACTOR=2

# ===== Cache =====
CACHE_MAX_SIZE=1000
CACHE_EVICTION=LRU
COHERENCE_PROTOCOL=MESI
CACHE_TTL=300

# ===== Redis =====
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===== Metrics =====
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_INTERVAL=5.0

# ===== Logging =====
LOG_LEVEL=INFO
